{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "个人工具集",
  "version": "0.1.0",
  "identifier": "com.personal-tools.todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "publisher": "personal-tools",
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "个人工具集 - 任务和密码管理",
    "longDescription": "一个集成了待办事项管理和密码本的个人工具集应用，帮助您高效管理日常任务和安全存储密码信息。"
  },
  "app": {
    "windows": [
      {
        "title": "个人工具集",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
